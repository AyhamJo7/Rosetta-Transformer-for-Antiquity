# Development and testing dependencies
# Use pip-compile requirements-dev.in > requirements-dev.txt to lock versions

-r requirements.in

# --- LINTING & FORMATTING ---
# black is pinned: the CI matrix (py3.9 + py3.10) otherwise resolves different
# black versions whose multiline-string formatting disagrees, so `black --check`
# passed on one Python and failed on the other. Pin so every job formats identically.
black==24.10.0
ruff
isort

# --- TYPE CHECKING ---
mypy
types-requests
types-PyYAML

# --- TESTING ---
pytest
pytest-cov
requests # For testing API endpoints

